        ]
      ]
    },
    "Set - prepare": {
      "main": [
        [
          {
            "node": "HTTP Request - Create",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "HTTP Request - Create": {
      "main": [
        [
          {
            "node": "DB - Persist (exemplo)",
