  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "webhook-receive",
        "responseMode": "onReceived",
        "responseData": "accepted"
      },
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [250, 300]
    },
    {
      "parameters": {
        "values": {
          "string": [
            {
              "name": "apiUrl",
              "value": "https://api.exemplo.com/resources"
            }
          ]
        },
        "options": {}
      },
      "name": "Set - prepare",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [450, 300]
    },
    {
      "parameters": {
        "requestMethod": "POST",
        "url": "={{$json[\"apiUrl\"]}}",
        "jsonParameters": true,
        "options": {
          "retry": {
            "enabled": true,
            "maxTries": 3,
            "delay": 2000,
            "factor": 2
          }
        },
        "bodyParametersJson": "={{$json}}"
      },
      "name": "HTTP Request - Create",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 1,
      "position": [650, 300]
    },
    {
      "parameters": {
        "operation": "insert",
        "table": "events",
        "columns": "data",
        "options": {}
      },
      "name": "DB - Persist (exemplo)",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 1,
      "position": [850, 300]
    },
    {
      "parameters": {
        "text": "Evento processado com sucesso: {{$node[\"HTTP Request - Create\"].json[\"id\"]}}"
      },
      "name": "Slack Notify",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 1,
      "position": [1050, 300]
    }
  ],
  "connections": {
    "Webhook": {
      "main": [
        [
          {
            "node": "Set - prepare",
            "type": "main",
            "index": 0
