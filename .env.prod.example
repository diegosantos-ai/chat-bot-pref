# ========================================
# TerezIA - Variaveis de Ambiente (PRODUCAO)
# ========================================
# Copie para .env e configure os valores reais
# NUNCA faca commit deste arquivo com tokens reais!

# APP
ENV=prod
DEBUG=false

# LLM - Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MAX_TOKENS=1024
GEMINI_TEMPERATURE=0.3

# DATABASE - PostgreSQL
# Formato: postgresql://usuario:senha@host:porta/banco
DATABASE_URL=
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
USER_HASH_SALT=

# VECTOR STORE - ChromaDB
CHROMA_PERSIST_DIR=./chroma_data
RAG_COLLECTION_NAME=rag_ba_rag_piloto_2026_01_v1

# RAG
RAG_BASE_ID=BA-RAG-PILOTO-2026.01.v1
RAG_TOP_K=7

# EMBEDDING PROVIDER
# Opções: default | gemini | openai | qwen
# "default" usa all-MiniLM-L6-v2 (ChromaDB built-in, sem custo adicional)
# gemini/openai/qwen usam a API do OpenRouter com OPENROUTER_API_KEY
# Recomendado para melhor semântica no piloto: openai
EMBEDDING_PROVIDER=openai
OPENROUTER_API_KEY=   # Necessário para provedores gemini, openai e qwen
# Override global opcional de modelo (prioridade máxima)
EMBEDDING_MODEL_OVERRIDE=
# Overrides por provedor (mantém default do código se vazio)
EMBEDDING_MODEL_GEMINI=google/gemini-embedding-001
EMBEDDING_MODEL_OPENAI=openai/text-embedding-3-large
EMBEDDING_MODEL_QWEN=qwen/qwen3-embedding-8b
# Robustez/performance de requisições de embedding
EMBEDDING_BATCH_SIZE=32
EMBEDDING_REQUEST_TIMEOUT_SECONDS=60
EMBEDDING_MAX_RETRIES=3
RAG_MIN_SCORE=0.35

# POLICY GUARD
POLICY_MAX_MESSAGE_LENGTH=2000
POLICY_BLOCKED_PATTERNS=
POLICY_PUBLIC_COMMENT_MAX_LENGTH=280

# META API (Instagram/Facebook) - PAGINA DO CLIENTE
# Obter no Facebook Developers: https://developers.facebook.com
META_APP_SECRET_FACEBOOK=
META_APP_SECRET_INSTAGRAM=
META_PAGE_ID_FACEBOOK=
META_PAGE_ID_INSTAGRAM=
META_ACCESS_TOKEN_FACEBOOK=
META_ACCESS_TOKEN_INSTAGRAM=
META_WEBHOOK_VERIFY_TOKEN=
META_WEBHOOK_VERIFY_TOKEN_FACEBOOK=
META_WEBHOOK_VERIFY_TOKEN_INSTAGRAM=
META_API_VERSION=v19.0

# META API (Legacy - usar apenas se necessario)
META_PAGE_ID=
META_APP_SECRET=

# RESPONSE FORMATTING
RESPONSE_MODE_INBOX_MAX_LENGTH=1000
RESPONSE_MODE_PUBLIC_MAX_LENGTH=280

# ========================================
# SECURITY - CORS e Rate Limiting
# ========================================
# CORS_ORIGINS: Dominios permitidos em producao
# IMPORTANTE: Nao use ["*"] em producao!
CORS_ORIGINS=["https://terezia.prefeitura.com.br", "https://www.facebook.com", "https://www.instagram.com"]

# RATE_LIMIT_ENABLED: Ativa/desativa rate limiting
RATE_LIMIT_ENABLED=true

# RATE_LIMIT_PER_MINUTE: Limite de requests por minuto para API publica
RATE_LIMIT_PER_MINUTE=30

# RATE_LIMIT_WEBHOOK_PER_MINUTE: Limite especifico para webhook do Meta
RATE_LIMIT_WEBHOOK_PER_MINUTE=60

# ========================================
# SECRETS MANAGER (AWS)
# ========================================
# Para producao, recomenda-se usar AWS Secrets Manager
USE_SECRETS_MANAGER=true

# AWS_REGION: Regiao da AWS
AWS_REGION=sa-east-1

# AWS_SECRET_NAME: Nome do secret no AWS Secrets Manager
# Formato esperado no AWS:
# {
#   "GEMINI_API_KEY": "...",
#   "DATABASE_URL": "...",
#   "META_ACCESS_TOKEN_FACEBOOK": "...",
#   "META_ACCESS_TOKEN_INSTAGRAM": "...",
#   "META_PAGE_ID_FACEBOOK": "...",
#   "META_PAGE_ID_INSTAGRAM": "...",
#   "META_APP_SECRET_FACEBOOK": "...",
#   "META_APP_SECRET_INSTAGRAM": "...",
#   "META_WEBHOOK_VERIFY_TOKEN": "...",
#   "USER_HASH_SALT": "...",
#   "ADMIN_API_KEY": "..."
# }
AWS_SECRET_NAME=terezia/prod

# ========================================
# ADMIN API
# ========================================
# ADMIN_API_KEY: Chave para acessar endpoints admin (analytics, etc.)
ADMIN_API_KEY=

# Configuracoes do banco (redundante com DATABASE_URL, para compatibilidade)
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=
