# ========================================
# Nexo Basis Governador - Variaveis de Ambiente (PRODUCAO)
# ========================================
# Copie para .env e configure os valores reais
# NUNCA faca commit deste arquivo com tokens reais!

# APP
ENV=prod
DEBUG=false

# LLM - Gemini (Base Provider)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MAX_TOKENS=1024
GEMINI_TEMPERATURE=0.3

# DATABASE - PostgreSQL Compartilhado (Row-Level Security)
# Roteando para instâncias da infra_nexo-network
# Formato: postgresql://usuario:senha@host:porta/banco
DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@nexo-postgres:5432/core_saas_gov
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
USER_HASH_SALT=

# VECTOR STORE - ChromaDB Compartilhado
CHROMA_URL=http://nexo-chromadb:8000

# REDIS CACHE (Compartilhado)
REDIS_URL=redis://nexo-redis:6379

# EMBEDDING PROVIDER
# Opções: default | gemini | openai | qwen
# "default" usa all-MiniLM-L6-v2 (ChromaDB built-in, sem custo adicional)
# gemini/openai/qwen usam a API do OpenRouter com OPENROUTER_API_KEY
# Recomendado para melhor semântica no piloto: openai
EMBEDDING_PROVIDER=openai
OPENROUTER_API_KEY=   # Necessário para provedores gemini, openai e qwen
# Override global opcional de modelo (prioridade máxima)
EMBEDDING_MODEL_OVERRIDE=
# Overrides por provedor (mantém default do código se vazio)
EMBEDDING_MODEL_GEMINI=google/gemini-embedding-001
EMBEDDING_MODEL_OPENAI=openai/text-embedding-3-large
EMBEDDING_MODEL_QWEN=qwen/qwen3-embedding-8b
# Robustez/performance de requisições de embedding
EMBEDDING_BATCH_SIZE=32
EMBEDDING_REQUEST_TIMEOUT_SECONDS=60
EMBEDDING_MAX_RETRIES=3
RAG_MIN_SCORE=0.35

# POLICY GUARD
POLICY_MAX_MESSAGE_LENGTH=2000
POLICY_BLOCKED_PATTERNS=
POLICY_PUBLIC_COMMENT_MAX_LENGTH=280

# ========================================
# SECURITY - CORS e Rate Limiting
# ========================================
# CORS_ORIGINS: Dominios permitidos em producao
# IMPORTANTE: Nao use ["*"] em producao!
CORS_ORIGINS=["https://gov.nexobasis.com.br", "https://www.facebook.com", "https://www.instagram.com"]

# RATE_LIMIT_ENABLED: Ativa/desativa rate limiting
RATE_LIMIT_ENABLED=true

# RATE_LIMIT_PER_MINUTE: Limite de requests por minuto para API publica
RATE_LIMIT_PER_MINUTE=60

# RATE_LIMIT_WEBHOOK_PER_MINUTE: Limite especifico para webhook do Meta
RATE_LIMIT_WEBHOOK_PER_MINUTE=120

# ========================================
# ADMIN API
# ========================================
# ADMIN_API_KEY: Chave para acessar endpoints admin (analytics, etc.)
ADMIN_API_KEY=
