name: CI

on:
  push:
    branches:
      - main
      - develop
      - "chore/**"
  pull_request:
    branches:
      - main
      - develop
  workflow_dispatch:

concurrency:
  group: ci-${{ github.ref }}
  cancel-in-progress: true

permissions:
  contents: read

env:
  PYTHONUNBUFFERED: "1"
  PIP_DISABLE_PIP_VERSION_CHECK: "1"

jobs:
  quality:
    name: Quality Gates
    runs-on: ubuntu-latest
    timeout-minutes: 15

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"
          cache: "pip"

      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip setuptools wheel
          python -m pip install -r requirements.txt
          python -m pip install -r requirements-dev.txt

      - name: Lint minimo do runtime
        run: python scripts/lint_runtime.py

      - name: Varredura anti-residuos historicos
        run: python scripts/check_runtime_residues.py

      - name: Compileall
        run: python -m compileall app scripts tests

      - name: Pytest
        run: python -m pytest tests -q

  docker-build-and-smoke:
    name: Docker Build And Smoke
    runs-on: ubuntu-latest
    needs: quality
    timeout-minutes: 25

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"
          cache: "pip"

      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip setuptools wheel
          python -m pip install -r requirements.txt

      - name: Validate docker compose
        run: |
          docker compose -f docker-compose.yml config
          docker compose -f docker-compose.yml -f docker-compose.local.yml config

      - name: Validate Docker build
        run: docker build -t chat-pref-ci -f Dockerfile .

      - name: Run smoke prod reuse
        run: |
          docker compose -f docker-compose.yml up -d --build
          until [ "$(docker inspect -f '{{.State.Health.Status}}' chat-pref-api 2>/dev/null)" = "healthy" ]; do sleep 1; done
          python scripts/smoke_tests.py \
            --env prod \
            --runtime-mode reuse \
            --tenant-id prefeitura-vila-serena \
            --tenant-manifest tenants/prefeitura-vila-serena/tenant.json \
            --phase-report fase11 \
            --json-out artifacts/fase11-smoke-prod.json

      - name: Upload smoke artifact
        uses: actions/upload-artifact@v4
        if: always()
        with:
          name: fase11-smoke-prod
          path: artifacts/fase11-smoke-prod.json

      - name: Teardown docker
        if: always()
        run: docker compose -f docker-compose.yml down -v

  genai-dry-run:
    name: GenAI Dry-Run Regression
    runs-on: ubuntu-latest
    needs: quality
    timeout-minutes: 10

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"
          cache: "pip"

      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip setuptools wheel
          python -m pip install -r requirements.txt
          python -m pip install -r requirements-dev.txt

      - name: Run offline RAG Evaluation (Mock)
        env:
          LLM_PROVIDER: mock
        run: |
          python scripts/run_phase4_rag_evaluation.py \
            --manifest benchmark_datasets/tenants/prefeitura-vila-serena/benchmark_v1/dataset_manifest.json \
            --tenant-id prefeitura-vila-serena \
            --experiment-name "ci-genai-dry-run" \ \
            --tracking-dir "tmp/mlflow_ci_run" \
            --max-cases 3

      - name: Upload MLflow Tracking Artifacts
        uses: actions/upload-artifact@v4
        if: always()
        with:
          name: genai-ci-mlflow-tracking
          path: tmp/mlflow_ci_run/
