 killall nano
 grep -A 10 "run_phase4_rag_evaluation" .github/workflows/ci.yml
 cat tmp_sed.sh || echo ""
 cat .github/workflows/ci.yml | grep -A 15 "Run offline RAG"
 sed -i 's/LLM_PROVIDER: mock/LLM_PROVIDER: mock\n          MLFLOW_RUN_NAME: ci-dry-run-${{ github.sha }}\n          GIT_COMMIT: ${{ github.sha }}\n          GIT_BRANCH: ${{ github.head_ref || github.ref_name }}/g' .github/workflows/ci.yml
 git checkout -- .github/workflows/ci.yml
