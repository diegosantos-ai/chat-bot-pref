 cat scripts/run_phase4_rag_evaluation.py | grep -E "cases_total|cases_evaluated" -B 2 -A 5
 cat tmp/mlflow_ci_run/run_reports/*_run.json | grep -A 10 "cases_total"
 killall nano && cat tmp/mlflow_ci_run/run_reports/*_run.json | grep -A 10 "cases_total"
 git branch
 ps aux | grep zsh
 cat scripts/run_phase4_rag_evaluation.py | grep faithfulness
 cat << 'EOF' > scripts/evaluate_genai_ci_gate.py
import sys
import json
from pathlib import Path

def evaluate_gate(reports_dir: Path) -> int:
    run_files = list(reports_dir.glob("*_run.json"))
    if not run_files:
        print("FAIL: Nenhum arquivo _run.json encontrado no tracking-dir.")
        return 1

    report_file = run_files[0]
    try:
        report = json.loads(report_file.read_text())
    except Exception as e:
        print(f"FAIL: Parse do relatorio rebentado. {e}")
        return 1

    cases_total = report.get("cases_total", 0)
    cases_evaluated = report.get("cases_evaluated", 0)

    if cases_total == 0 or cases_evaluated == 0:
        print("FAIL: O runner nao preencheu nenum caso (cases_evaluated=0).")
        return 1

    if cases_evaluated < cases_total:
         print(f"FAIL: Foram pulados casos no CI. Evaluated: {cases_evaluated} / Total: {cases_total}")
         return 1

    print("PASS: Estrutura do Json do Runner e passagens sistemicas validas!")
    print("AVISO: Tracking numerico rigoroso como faithfulness e relevance ignorados no mock-provider.")

    return 0

if __name__ == "__main__":
    workdir = Path(sys.argv[1]) if len(sys.argv) > 1 else Path("tmp/mlflow_ci_run/run_reports")
    sys.exit(evaluate_gate(workdir))
EOF
 cat << 'EOF' >> docs-LLMOps/fases/FASE7-CI-GENAI-REGRESSAO.md

## Critérios de Bloqueio em CI e Regra de Decisão (Gate)

### Bloqueio Duro (Hard-Fail / Exit 1)
O pipeline será derrubado instantaneamente em qualquer uma das hipóteses:
- O runner gerar de saída código de erro estrutural do Python.
- Nenhum artefato JSON rastreável for deixado pela run em `tmp/mlflow_ci_run/run_reports/`.
- O valor inferido de `cases_evaluated` for menor que `cases_total` no JSON do benchmark, significando que um artefato crashou parte do sub-range sem corromper o executor em si.

### Bloqueio por Qualidade (Soft-Fail)
- Inexistente nesse momento.

### Aviso Sancionável (Skip)
- Qualquer ruído oriundo do `LLM_PROVIDER=mock` nas métricas semânticas absolutas como `faithfulness_mean` ou `answer_relevance_mean`. Como o mock é rígido, não aplicaremos trava sobre a *nota* nesta triagem.
EOF
 chmod +x scripts/evaluate_genai_ci_gate.py
 sed -i '/Upload MLflow Tracking Artifacts/i \      - name: Validate GenAI Regression Gate (Hard-fail)\n        run: python scripts/evaluate_genai_ci_gate.py "tmp/mlflow_ci_run/run_reports"\n' .github/workflows/ci.yml
 cat scripts/evaluate_genai_ci_gate.py
