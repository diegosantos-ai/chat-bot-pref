# {bot_name} - Caddyfile para HTTPS automático
# ==========================================
# Caddy obtém certificado SSL automaticamente via Let's Encrypt
#
# IMPORTANTE: Substitua SEU_DOMINIO pelo domínio real antes de usar
# Exemplo: terezia.prefeitura.com.br

# Opção 1: Com domínio real (recomendado para produção)
# Descomente e configure quando tiver o domínio:
#
# terezia.seudominio.com.br {
#     reverse_proxy terezia:8000
#     
#     # Headers de segurança
#     header {
#         X-Content-Type-Options nosniff
#         X-Frame-Options DENY
#         X-XSS-Protection "1; mode=block"
#     }
#     
#     # Logs
#     log {
#         output file /var/log/caddy/access.log
#         format json
#     }
# }

# Opção 2: Desenvolvimento/teste local (IP direto, sem HTTPS)
# Use esta opção para testar antes de configurar o domínio
:80 {
    reverse_proxy terezia:8000
}

# Opção 3: Com ngrok/cloudflared (túnel temporário)
# Se estiver usando túnel, esta config funciona:
# :80 {
#     reverse_proxy localhost:8000
# }
