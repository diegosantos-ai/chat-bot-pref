{
  "dashboard": {
    "id": null,
    "title": "{bot_name} - Overview de Servicos",
    "tags": ["overview", "services", "monitoring"],
    "timezone": "browser",
    "schemaVersion": 38,
    "refresh": "30s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Status dos Servicos",
        "type": "stat",
        "gridPos": {"h": 4, "w": 24, "x": 0, "y": 0},
        "datasource": {"type": "loki", "uid": "${loki}"},
        "targets": [
          {"expr": "count_over_time({job=\"nginx\"}[5m])"},
          {"expr": "count_over_time({job=\"systemd-journal\", unit=\"terezia-api.service\"}[5m])"}
        ]
      },
      {
        "id": 2,
        "title": "Logs por Servico (ultima hora)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
        "datasource": {"type": "loki", "uid": "${loki}"},
        "targets": [
          {"expr": "sum by (job) (rate({job=~\"nginx|systemd-journal\"}[5m]))", "legendFormat": "{{job}}"}
        ]
      },
      {
        "id": 3,
        "title": "Erros Recentes",
        "type": "logs",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
        "datasource": {"type": "loki", "uid": "${loki}"},
        "targets": [
          {"expr": "{job=~\"nginx|systemd-journal\"} |= \"error\" or \"ERROR\" or \"500\" or \"critical\""}
        ]
      },
      {
        "id": 4,
        "title": "Nginx - Requisicoes por Minuto",
        "type": "stat",
        "gridPos": {"h": 4, "w": 8, "x": 0, "y": 12},
        "datasource": {"type": "loki", "uid": "${loki}"},
        "targets": [
          {"expr": "count_over_time({job=\"nginx\", logtype=\"access\"}[1m])"}
        ]
      },
      {
        "id": 5,
        "title": "{bot_name} API - Logs/min",
        "type": "stat",
        "gridPos": {"h": 4, "w": 8, "x": 8, "y": 12},
        "datasource": {"type": "loki", "uid": "${loki}"},
        "targets": [
          {"expr": "count_over_time({job=\"systemd-journal\", unit=\"terezia-api.service\"}[1m])"}
        ]
      },
      {
        "id": 6,
        "title": "Erros HTTP 5xx",
        "type": "stat",
        "gridPos": {"h": 4, "w": 8, "x": 16, "y": 12},
        "datasource": {"type": "loki", "uid": "${loki}"},
        "targets": [
          {"expr": "count_over_time({job=\"nginx\", logtype=\"access\"} |~ \"HTTP/[0-9]+ 5[0-9][0-9]\" [5m])"}
        ]
      },
      {
        "id": 7,
        "title": "Ultimos Logs - Todos os Servicos",
        "type": "logs",
        "gridPos": {"h": 10, "w": 24, "x": 0, "y": 16},
        "datasource": {"type": "loki", "uid": "${loki}"},
        "targets": [
          {"expr": "{job=~\"nginx|systemd-journal\"}"}
        ]
      }
    ]
  },
  "overwrite": true
}
