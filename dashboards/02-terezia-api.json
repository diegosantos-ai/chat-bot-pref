{
  "dashboard": {
    "id": null,
    "title": "{bot_name} - API (Uvicorn)",
    "tags": ["terezia", "api", "uvicorn", "logs"],
    "timezone": "browser",
    "schemaVersion": 38,
    "refresh": "10s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "templating": {
      "list": [
        {
          "name": "level",
          "type": "query",
          "datasource": {"type": "loki", "uid": "${loki}"},
          "query": "label_values({job=\"systemd-journal\", unit=\"terezia-api.service\"}, level)",
          "multi": true,
          "includeAll": true,
          "allValue": ".*"
        }
      ]
    },
    "panels": [
      {
        "id": 1,
        "title": "Logs por Nível",
        "type": "timeseries",
        "gridPos": {"h": 6, "w": 12, "x": 0, "y": 0},
        "datasource": {"type": "loki", "uid": "${loki}"},
        "targets": [
          {
            "expr": "sum by (level) (rate({job=\"systemd-journal\", unit=\"terezia-api.service\", level=~\"$level\"}[5m]))",
            "refId": "A",
            "legendFormat": "{{level}}"
          }
        ]
      },
      {
        "id": 2,
        "title": "Total de Logs (última hora)",
        "type": "stat",
        "gridPos": {"h": 3, "w": 4, "x": 12, "y": 0},
        "datasource": {"type": "loki", "uid": "${loki}"},
        "targets": [
          {
            "expr": "count_over_time({job=\"systemd-journal\", unit=\"terezia-api.service\"}[1h])",
            "refId": "A"
          }
        ]
      },
      {
        "id": 3,
        "title": "Erros (ERROR/CRITICAL)",
        "type": "stat",
        "gridPos": {"h": 3, "w": 4, "x": 16, "y": 0},
        "datasource": {"type": "loki", "uid": "${loki}"},
        "targets": [
          {
            "expr": "count_over_time({job=\"systemd-journal\", unit=\"terezia-api.service\"} |= \"ERROR\" or \"CRITICAL\" [1h])",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 10},
                {"color": "red", "value": 50}
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Requisições Webhook",
        "type": "stat",
        "gridPos": {"h": 3, "w": 4, "x": 20, "y": 0},
        "datasource": {"type": "loki", "uid": "${loki}"},
        "targets": [
          {
            "expr": "count_over_time({job=\"systemd-journal\", unit=\"terezia-api.service\"} |= \"webhook\" [1h])",
            "refId": "A"
          }
        ]
      },
      {
        "id": 5,
        "title": "Chamadas à API Meta",
        "type": "stat",
        "gridPos": {"h": 3, "w": 4, "x": 12, "y": 3},
        "datasource": {"type": "loki", "uid": "${loki}"},
        "targets": [
          {
            "expr": "count_over_time({job=\"systemd-journal\", unit=\"terezia-api.service\"} |= \"graph.facebook.com\" [1h])",
            "refId": "A"
          }
        ]
      },
      {
        "id": 6,
        "title": "Chamadas Gemini AI",
        "type": "stat",
        "gridPos": {"h": 3, "w": 4, "x": 16, "y": 3},
        "datasource": {"type": "loki", "uid": "${loki}"},
        "targets": [
          {
            "expr": "count_over_time({job=\"systemd-journal\", unit=\"terezia-api.service\"} |= \"generativelanguage.googleapis.com\" [1h])",
            "refId": "A"
          }
        ]
      },
      {
        "id": 7,
        "title": "Warnings",
        "type": "stat",
        "gridPos": {"h": 3, "w": 4, "x": 20, "y": 3},
        "datasource": {"type": "loki", "uid": "${loki}"},
        "targets": [
          {
            "expr": "count_over_time({job=\"systemd-journal\", unit=\"terezia-api.service\"} |= \"WARNING\" [1h])",
            "refId": "A"
          }
        ]
      },
      {
        "id": 8,
        "title": "Erros (ERROR/CRITICAL/EXCEPTION)",
        "type": "logs",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6},
        "datasource": {"type": "loki", "uid": "${loki}"},
        "targets": [
          {
            "expr": "{job=\"systemd-journal\", unit=\"terezia-api.service\"} |= \"ERROR\" or \"CRITICAL\" or \"EXCEPTION\"",
            "refId": "A"
          }
        ]
      },
      {
        "id": 9,
        "title": "Webhooks Recebidos",
        "type": "logs",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6},
        "datasource": {"type": "loki", "uid": "${loki}"},
        "targets": [
          {
            "expr": "{job=\"systemd-journal\", unit=\"terezia-api.service\"} |= \"webhook\"",
            "refId": "A"
          }
        ]
      },
      {
        "id": 10,
        "title": "Todos os Logs da API",
        "type": "logs",
        "gridPos": {"h": 10, "w": 24, "x": 0, "y": 14},
        "datasource": {"type": "loki", "uid": "${loki}"},
        "targets": [
          {
            "expr": "{job=\"systemd-journal\", unit=\"terezia-api.service\", level=~\"$level\"}",
            "refId": "A"
          }
        ]
      }
    ]
  },
  "overwrite": true
}
