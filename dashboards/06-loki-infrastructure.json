{
  "dashboard": {
    "id": null,
    "title": "{bot_name} - Loki Infrastructure",
    "tags": ["loki", "promtail", "infrastructure", "logs"],
    "timezone": "browser",
    "schemaVersion": 38,
    "refresh": "30s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "templating": {
      "list": []
    },
    "panels": [
      {
        "id": 1,
        "title": "Status Loki",
        "type": "stat",
        "gridPos": {"h": 4, "w": 8, "x": 0, "y": 0},
        "datasource": {"type": "loki", "uid": "${loki}"},
        "targets": [
          {
            "expr": "count_over_time({job=\"systemd-journal\", unit=~\"docker-terezia-loki.*\"}[5m])",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                {"color": "red", "value": null},
                {"color": "green", "value": 1}
              ]
            },
            "mappings": [
              {"options": {"0": {"text": "Offline", "color": "red"}}, "type": "value"},
              {"options": {"from": 1, "to": 999999}, "type": "range", "result": {"text": "Online", "color": "green"}}
            ]
          }
        }
      },
      {
        "id": 2,
        "title": "Status Promtail",
        "type": "stat",
        "gridPos": {"h": 4, "w": 8, "x": 8, "y": 0},
        "datasource": {"type": "loki", "uid": "${loki}"},
        "targets": [
          {
            "expr": "count_over_time({job=\"systemd-journal\", unit=~\"docker-terezia-promtail.*\"}[5m])",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                {"color": "red", "value": null},
                {"color": "green", "value": 1}
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "Volume Total de Logs",
        "type": "stat",
        "gridPos": {"h": 4, "w": 8, "x": 16, "y": 0},
        "datasource": {"type": "loki", "uid": "${loki}"},
        "targets": [
          {
            "expr": "count_over_time({job=~\".+\"}[1h])",
            "refId": "A"
          }
        ]
      },
      {
        "id": 4,
        "title": "Jobs Ativos",
        "type": "table",
        "gridPos": {"h": 6, "w": 12, "x": 0, "y": 4},
        "datasource": {"type": "loki", "uid": "${loki}"},
        "targets": [
          {
            "expr": "sum by (job) (count_over_time({job=~\".+\"}[1h]))",
            "refId": "A",
            "instant": true
          }
        ]
      },
      {
        "id": 5,
        "title": "Volume por Job",
        "type": "piechart",
        "gridPos": {"h": 6, "w": 12, "x": 12, "y": 4},
        "datasource": {"type": "loki", "uid": "${loki}"},
        "targets": [
          {
            "expr": "sum by (job) (count_over_time({job=~\".+\"}[1h]))",
            "refId": "A",
            "legendFormat": "{{job}}"
          }
        ]
      },
      {
        "id": 6,
        "title": "Taxa de Ingestão (logs/min)",
        "type": "timeseries",
        "gridPos": {"h": 6, "w": 24, "x": 0, "y": 10},
        "datasource": {"type": "loki", "uid": "${loki}"},
        "targets": [
          {
            "expr": "sum(rate({job=~\".+\"}[5m]))",
            "refId": "A",
            "legendFormat": "Total"
          },
          {
            "expr": "sum by (job) (rate({job=~\".+\"}[5m]))",
            "refId": "B",
            "legendFormat": "{{job}}"
          }
        ]
      },
      {
        "id": 7,
        "title": "Logs do Loki",
        "type": "logs",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
        "datasource": {"type": "loki", "uid": "${loki}"},
        "targets": [
          {
            "expr": "{job=\"systemd-journal\", unit=~\"docker-terezia-loki.*\"}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 8,
        "title": "Logs do Promtail",
        "type": "logs",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
        "datasource": {"type": "loki", "uid": "${loki}"},
        "targets": [
          {
            "expr": "{job=\"systemd-journal\", unit=~\"docker-terezia-promtail.*\"}",
            "refId": "A"
          }
        ]
      }
    ]
  },
  "overwrite": true
}
